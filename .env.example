# PostgreSQL / pgvector
POSTGRES_DB=digital_expert_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/digital_expert_agents

# MinIO object storage
MINIO_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=case-documents
MINIO_SECURE=false

# LLM provider — "fpt" (default, uses FPT_API_KEY below), "openai", "anthropic"
# or "mock" (no network calls, fully deterministic — used by default in tests
# and whenever no API key is configured, so the app never crashes without one).
LLM_PROVIDER=fpt
LLM_MODEL=SaoLa3.1-medium
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Optional GLM provider
GLM_API_KEY=replace-with-your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_REQUEST_TIMEOUT_SECONDS=60
# FPT AI Marketplace — used for both chat (LLMProvider) and embeddings (RAG)
FPT_API_KEY=replace-with-your-fpt-api-key
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_REQUEST_TIMEOUT_SECONDS=60
EMBEDDING_PROVIDER=fpt
EMBEDDING_MODEL=Vietnamese_Embedding
EMBEDDING_DIMENSIONS=512
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TRUST_REMOTE_CODE=true
EMBEDDING_CACHE_DIR=.cache/huggingface

# Application URLs
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

