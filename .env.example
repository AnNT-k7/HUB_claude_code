# PostgreSQL / pgvector
POSTGRES_DB=digital_expert_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/digital_expert_agents

# MinIO object storage
MINIO_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CASE_BUCKET=case-documents
MINIO_POLICY_BUCKET=bank-policies
MINIO_SECURE=false
MAX_UPLOAD_BYTES=20971520

# FPT AI Marketplace (OpenAI-compatible). Put secrets only in .env/secret manager.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL=Vietnamese_Embedding
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://mkp-api.fptcloud.com
LLM_API_KEY=
LLM_MODEL=GLM-5.2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
AGENT_DOCUMENT_CONTEXT_CHARS=60000

# Workflow and demo bootstrap
MAX_DEBATE_ROUNDS=3
SEED_DEMO_POLICIES=true
SEED_DEMO_CASE=true
DEMO_OFFICER_ID=demo-officer
POLICY_ADMIN_OFFICER_IDS=["demo-officer"]

# Application URLs
APP_DEBUG=false
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
